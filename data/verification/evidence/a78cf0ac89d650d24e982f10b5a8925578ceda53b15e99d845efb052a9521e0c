face-base-moisturizer-primer"><script async="" src="https://cdn2.smartgiftit.com/scripts/widgets/gift-basket.js"></script><script src="https://www.youtube.com/iframe_api"></script><script type="text/javascript" src="https://www.bobbibrowncosmetics.com/assets/ee711e9bba8762da77a5df9e7ae59e09fe217ba0600"></script><script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":["FAQPage"],"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#faq","url":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer","name":"","datePublished":"2026-07-16T15:07:06-04:00","dateModified":"2026-07-16T15:07:06-04:00","description":"","mainEntity":[{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-1"},{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-2"},{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-3"},{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-4"},{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-5"},{"@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-6"}],"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-1","position":1,"name":"WHAT ARE THE BENEFITS OF WEARING A PRIMER? ","acceptedAnswer":{"@type":"Answer","text":"<p>Primer helps grip makeup and create a seamless canvas for application. It can also help improve the look of makeup. When you use Vitamin Enriched Face Base as your primer, you get the bonus of skin-plumping hydration.</p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-2","position":2,"name":"WHEN SHOULD I USE A FACE PRIMER? ","acceptedAnswer":{"@type":"Answer","text":"<p>Primers are formulated to help grip makeup for seamless makeup application and improve the look of foundation.</p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-3","position":3,"name":"CAN I USE VITAMIN ENRICHED FACE BASE AS A MOISTURIZER? ","acceptedAnswer":{"@type":"Answer","text":"<p>Yes, Vitamin Enriched Face Base was initially developed as a moisturizer. It was only after our artists noticed how it created a smooth and seamless canvas for makeup that it was renamed Vitamin Enriched Face Base.</p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-4","position":4,"name":"DO I PUT MOISTURIZER ON BEFORE VITAMIN ENRICHED FACE BASE? ","acceptedAnswer":{"@type":"Answer","text":"<p>If you have normal to oily skin, you don’t need to use another moisturizer before Vitamin Enriched Face Base. Our 2-in-1 moisturizer and primer combines the hydration of a moisturizer with the benefits of primer to help grip makeup and create a seamless base for application. If you have dry to very dry skin, you may want to apply a moisturizer beforehand for extra hydration.</p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-5","position":5,"name":"DO I PUT MAKEUP PRIMER UNDER MY EYES? ","acceptedAnswer":{"@type":"Answer","text":"<p>We recommend using Vitamin Enriched Eye Base on the delicate undereye area.</p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer#question-6","position":6,"name":"DOES SPF GO ON BEFORE OR AFTER PRIMER? ","acceptedAnswer":{"@type":"Answer","text":"<p>SPF should be applied as the last step of your skincare regimen before makeup. Use it after applying Vitamin Enriched Face Base, our 2-in-1 moisturizer and primer. If you are using a separate moisturizer and primer, apply SPF after your moisturizer.</p>","inLanguage":"en-US"},"inLanguage":"en-US"}]}</script><meta name="google-site-verification" content="jPdvKcLSzV-Rj-LYHCbT2GKVFn2Y-KjeZ-erDYAfEKM"><meta name="msvalidate.01" content="F70C8C52EB5EA67002C696334C064EF5"><link rel="shortcut icon" href="https://www.bobbibrowncosmetics.com/sites/bobbibrown/themes/bb_base/favicon.ico"><link rel="preconnect" href="https://ncsa.sdapi.io/" crossorigin=""><script type="application/ld+json">{"@context":"http://schema.org/","@type":"ProductGroup","name":"Vitamin Enriched Face Base Moisturizer & Primer","image":"/media/export/cms/products/v2_1080x1080/bb_sku_E1LM01_1080x1080_0.jpg?width=1440&height=1440","description":"Bestselling hydrating moisturizer & multivitamin makeup primer","url":"https://www.bobbibrowncosmetics.com/product/14007/7485/skincare/moisturizer/vitamin-enriched-face-base-moisturizer-primer","brand":{"@type":"Brand","name":"Bobbi Brown Cosmetics","image":"https://www.bobbibrowncosmetics.com/media/export/cms/logo.png","url":"https://www.bobbibrowncosmetics.com/"},"sku":"E1LM01","productGroupID":7485,"aggregateRating":{"@type":"AggregateRating","ratingValue":4.8,"reviewCount":3650},"variesBy":"https:/