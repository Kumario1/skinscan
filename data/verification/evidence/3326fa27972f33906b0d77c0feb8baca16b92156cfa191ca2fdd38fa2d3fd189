            <section ID="id_link_61e7c0d8-26e7-5209-e053-2a91aa0a0659">
               <id root="d9c1b723-fa28-5680-e053-2995a90acb02"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <paragraph>Uses</paragraph>
                  <list listType="unordered">
                     <item>Helps prevent sunburn</item>
                     <item>If used as directed with other sun protection measures (see 
        
  
   <content styleCode="italics">
                           <content styleCode="bold">Directions</content>
                        </content>), decreases the risk of skin cancer and early skin aging caused by the sun 
       
 
  </item>
                  </list>
               </text>
               <effectiveTime value="20180103"/>
            </section>
         </component>
