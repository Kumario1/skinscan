               <code code="50567-7" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - WHEN USING SECTION"/>
               <text>
                  <paragraph>When using this product: avoid contact with eyes. If contact occurs, rinse thoroughly with water.</paragraph>
               </text>
               <effectiveTime value="20260703"/>
            </section>
         </component>
