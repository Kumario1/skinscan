               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <paragraph>Directions</paragraph>
                  <paragraph>Cleanse face to remove dirt and impurities.</paragraph>
                  <paragraph>Wash face and gently pat dry.</paragraph>
                  <paragraph>Dispense cream onto hands and apply directly to acne-prone areas.</paragraph>
                  <paragraph>Use twice daily (morning and evening).</paragraph>
                  <paragraph/>
               </text>
