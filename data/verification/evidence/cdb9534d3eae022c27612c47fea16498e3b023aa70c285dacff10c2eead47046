               <code code="50566-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - STOP USE SECTION"/>
               <text>
                  <paragraph>Stop use and ask a doctor if: significant facial swelling, large areas of red rash, intense itching or burning sensation.</paragraph>
               </text>
               <effectiveTime value="20260703"/>
            </section>
         </component>
