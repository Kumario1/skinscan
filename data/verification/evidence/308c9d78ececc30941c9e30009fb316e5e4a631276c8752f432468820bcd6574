          if (header.hasAttribute('style')) {
            let style = header.getAttribute('style');
            style = style.replace(/border-bottom:[^;]*(;|$)/gi, 'border-bottom: 1px solid #e5e7eb;');
            style = style.replace(/background-color:[^;]*(;|$)/gi, '');
            th.setAttribute('style', style);
