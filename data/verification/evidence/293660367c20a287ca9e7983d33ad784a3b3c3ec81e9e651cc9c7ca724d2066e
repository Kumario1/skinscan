            <section ID="id_link_0867da12-c413-d353-e063-6294a90ae2af">
               <id root="43fa5c4e-206e-4f3b-e063-6394a90a9fd9"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <paragraph>Helps prevent sunburn</paragraph>
                  <paragraph>If used as directed with other sun protection measures (see 
  <content styleCode="bold">Directions</content>), decreases the risk of skin cancer and early skin aging caused by the sun
 </paragraph>
               </text>
