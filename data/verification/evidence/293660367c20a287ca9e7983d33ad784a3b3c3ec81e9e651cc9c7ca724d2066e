               <id root="43fa51da-0765-85b5-e063-6294a90a6c48"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">For External use only</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Do not use</content> on damaged or broken skin
 </paragraph>
                  <paragraph>
                     <content styleCode="bold">When using this product</content>, keep out of eyes. Rinse with water to remove
 </paragraph>
