               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Stop use and ask a doctor</content> if rash occurs
 </paragraph>
