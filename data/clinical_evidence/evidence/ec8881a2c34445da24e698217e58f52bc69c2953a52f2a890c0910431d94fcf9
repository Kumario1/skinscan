  <h1 class="content-title text-center">FDA works to protect consumers from potentially harmful OTC skin lightening products</h1>
  
  	</div>

  </section>






                      </header>
                              
                                                          
                              <aside class="col-md-2" role="complementary">
                  <section id="block-entityviewcontent-3" data-block-plugin-id="entity_view:node" class="block block-ctools block-entity-viewnode clearfix">
  
    

        <div class="region region-">
        <nav id="section-nav"class="lcds-card lcds-section-nav lcds-section-nav--side hidden-xs hidden-sm">
      <ul class="lcds-section-nav__list lcds-section-nav--side__list">
        <li>

                    <a href="/drugs/drug-safety-and-availability/drug-safety-communications" class="lcds-section-nav__link lcds-section-nav--side__link lcds-section-nav__parent-link lcds-section-nav--side__parent-link">
