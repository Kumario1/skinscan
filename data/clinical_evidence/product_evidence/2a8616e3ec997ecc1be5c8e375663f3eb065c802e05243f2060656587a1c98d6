const ONE_YEAR = 60 * 60 * 24 * 365;

/* ---------- Cookie helpers ---------- */
function setOnEtldPlus1(name, value, maxAge) {
  const parts = location.hostname.split('.');
  const maxAgeStr = maxAge ? `Max-Age=${maxAge}; ` : '';
  for (let i = parts.length - 2; i >= 0; i--) {
    const domain = '.' + parts.slice(i).join('.');
    try {
      document.cookie = `${name}=${value}; ${maxAgeStr}Path=/; Domain=${domain}; SameSite=Lax; Secure`;
      if (document.cookie.includes(name + '=')) return domain;
    } catch (_) {}
  }
}

function getCookie(name) {
  return document.cookie
    .split('; ')
    .find(c => c.startsWith(name + '='))
    ?.split('=')[1];
}

/* ---------- Performance API ---------- */
function getValueFromPerformance(key) {
  const entry = performance.getEntriesByType('navigation')[0];
  const description = entry?.serverTiming?.find(e => e.name === '_cmp')?.description;

  if (!description) return undefined;

  // Encode the key the same way it appears in the description
  const encodedKey = encodeURIComponent(key);

  const regex = new RegExp(`${encodedKey}%22%3A%22(.+?)%22`);
  return description.match(regex)?.[1];
}
