               <id root="eaf596ef-9879-776c-e053-2a95a90abb4e"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <list listType="unordered">
                     <item>Sunscreen </item>
                     <item>Helps prevent sunburn</item>
                     <item>If used as directed with other sun protection measures (see 
   
        
  
   <content styleCode="bold">Directions</content>), decreases the risk of skin cancer and early skin aging caused by the sun 
  
       
 
  </item>
                  </list>
               </text>
               <effectiveTime value="20200915"/>
            </section>
         </component>
         <component>
