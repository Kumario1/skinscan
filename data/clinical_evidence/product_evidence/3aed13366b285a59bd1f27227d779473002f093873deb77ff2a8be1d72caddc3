               <text>
                  <paragraph>
                     <content styleCode="bold">Keep out of reach of children. </content>If swallowed, get medical help or contact a Poison Control Center right away. 
 
      

 </paragraph>
               </text>
               <effectiveTime value="20200915"/>
            </section>
