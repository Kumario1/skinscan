            <section>
               <id root="dc3027e2-ea30-47ca-8b78-be74beba1edb"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>Uses</title>
               <text>
                  <list listType="unordered" styleCode="disc">
                     <item>helps prevent sunburn</item>
                     <item>if used as directed with other sun protection measures (see <content styleCode="bold italics">
                           <linkHtml href="#dir">Directions</linkHtml>
                        </content>), decreases the risk of skin cancer and early skin aging caused by the sun</item>
                  </list>
               </text>
               <effectiveTime value="20201118"/>
            </section>
