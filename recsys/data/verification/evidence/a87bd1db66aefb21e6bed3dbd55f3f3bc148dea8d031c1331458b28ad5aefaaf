         <component>
            <section ID="Laf5e300c-11fc-4173-b153-a701b7fcca34">
               <id root="eb5ddc90-209b-2c41-e053-2995a90ae8d9"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <paragraph>Uses</paragraph>
                  <list listType="unordered">
                     <item>Helps prevent sunburn</item>
                     <item>If used as directed with other sun protection measures (see 
        
  
   
        
  
   <content styleCode="bold">Directions</content>), decreases the risk of skin cancer and early skin aging caused by the sun
       
 
  
       
 
  </item>
                  </list>
               </text>
               <effectiveTime value="20171010"/>
            </section>
         </component>
         <component>
            <section ID="L33a972ca-65dd-424b-afff-70b06065fcd4">
               <id root="eb5ddc90-209c-2c41-e053-2995a90ae8d9"/>
               <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
               <text>
                  <paragraph>Keep out of reach of children. If product is swallowed, get medical help or contact a Poison Control Center right away. </paragraph>
               </text>
               <effectiveTime value="20171010"/>
            </section>
         </component>
