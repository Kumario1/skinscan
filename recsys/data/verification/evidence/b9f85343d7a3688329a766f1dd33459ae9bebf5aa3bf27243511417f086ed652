                </button>
            </div>

            <div class="powered-by-rebuy">
                <a v-bind:href="'https://rebuyengine.com/?shop=' + config.shop.myshopify_domain" target="_blank" rel="noopener">
                    Powered by Rebuy
                </a>
            </div>

        </div>
    </div>
</div>
</script>


