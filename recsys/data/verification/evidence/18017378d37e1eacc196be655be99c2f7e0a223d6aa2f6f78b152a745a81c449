         <component>
            <section ID="id_link_705c11e1-f18d-09b4-e053-2991aa0aed78">
               <id root="ec5742f1-5281-6496-e053-2995a90a7075"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">
                        <content styleCode="italics">Uses</content>
                     </content>
                  </paragraph>
                  <paragraph>Helps Prevent Sunburn</paragraph>
                  <paragraph>If used as directed with other sun protection measures (see Directions), decreases the risk of Skin cancer and early skin aging caused by the sun</paragraph>
               </text>
               <effectiveTime value="20200125"/>
            </section>
         </component>
